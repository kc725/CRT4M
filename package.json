{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "backend:dev": "node scripts/start-backend.js",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:full": "concurrently \"npm run backend:dev\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"import('fs').then(f=>f.rmSync('dist',{recursive:true,force:true}))\"",
    "lint": "tsc --noEmit",
    "electron:dev": "cross-env ELECTRON_DEV=true concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:full": "cross-env ELECTRON_DEV=true concurrently \"npm run backend:dev\" \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder build --publish never"
  },
  "build": {
    "appId": "com.crt4m.app",
    "productName": "CRT4M",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    }
  },
  "dependencies": {
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.2",
    "wait-on": "^9.0.4"
  }
}
